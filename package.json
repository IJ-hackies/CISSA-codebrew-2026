{
  "name": "scholarsystem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:client & bun run dev:server & wait",
    "dev:client": "cd apps/client && bun run dev",
    "dev:server": "cd apps/server && bun run dev",
    "dev:proxy": "cd apps/proxy && bun run dev",
    "build": "bun run build:client",
    "build:client": "cd apps/client && bun run build",
    "start:server": "cd apps/server && bun run start",
    "start:proxy": "cd apps/proxy && bun run start",
    "lint": "cd apps/client && bun run lint",
    "format": "cd apps/client && bun run format"
  }
}
